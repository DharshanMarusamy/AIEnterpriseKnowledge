# Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# âš ï¸  NEVER commit the .env file to version control.

# --- Google Gemini AI ---
EKA_GEMINI_API_KEY=AIzaSyDSgOaXTbX88uAjueJEwwvJpugnE9oMdLQ

# --- PostgreSQL Database ---
# For local Docker: postgresql+asyncpg://eka_admin:password@localhost:5433/ai_enterprice
# For Railway: automatically set by Railway's PostgreSQL plugin as DATABASE_URL
DATABASE_URL=postgresql+asyncpg://eka_admin:change_me_in_production@localhost:5433/ai_enterprice
POSTGRES_USER=eka_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ai_enterprice

# --- JWT Authentication ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=super_secret_jwt_key_change_in_prod

# --- Redis ---
# For local Docker: redis://localhost:6379/0
# For Upstash (cloud): rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# --- Qdrant Vector DB ---
# For local Docker: http://localhost:6333
# For Qdrant Cloud: https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key_here
# --- OAuth SSO ---
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

